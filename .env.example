# bam-landing-page env vars
# Copy to `.env.local` and fill. All values fake here; never commit real secrets.

# --- Database (MongoDB) ---
# Three legacy variable names are referenced across the codebase. Standardize
# on MONGODB_URI long-term; keep the others set to the same value until a
# future plan consolidates the references.
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/bam_portfolio?retryWrites=true&w=majority"
MONGODB_CONNECTION_STRING="mongodb+srv://user:pass@cluster.mongodb.net/bam_portfolio?retryWrites=true&w=majority"
MONGO_URI="mongodb+srv://user:pass@cluster.mongodb.net/bam_portfolio?retryWrites=true&w=majority"
# Generic fallback used by some route handlers:
DATABASE_URL="mongodb+srv://user:pass@cluster.mongodb.net/bam_portfolio?retryWrites=true&w=majority"

# --- Auth (NextAuth v4) ---
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# JWT signing used by custom auth paths alongside NextAuth:
JWT_SECRET="generate-with-openssl-rand-base64-32"

# --- Admin ---
ADMIN_EMAIL="admin@example.com"
ADMIN_API_KEY="some-server-only-admin-key"
# Public mirror referenced by client-side code — should be removed during a
# follow-up security pass (admin keys must never be NEXT_PUBLIC_*):
NEXT_PUBLIC_ADMIN_API_KEY=""

# --- reCAPTCHA v3 (workout feedback + contact forms) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="6LcXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
RECAPTCHA_SECRET_KEY="6LcYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY"

# --- SMTP (nodemailer, outbound email from form notifications) ---
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-pass"

# --- Cloudinary (media) ---
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# --- Google Gemini (AI features) ---
GEMINI_API_KEY="your-gemini-api-key"
# Public mirror referenced by client code — should be removed during a
# follow-up security pass (API keys must never be NEXT_PUBLIC_*):
NEXT_PUBLIC_GEMINI_API_KEY=""

# --- AI system prompt override ---
SYSTEM_PROMPT=""

# --- Node runtime flag (rarely set manually) ---
# NODE_ENV="development"
